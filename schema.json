{
  "database": "sistema_banheiro",
  "tables": {
    "alunos": {
      "columns": ["id_alunos", "nome"],
      "primaryKey": "id_alunos"
    },
    "registros_saida": {
      "columns": ["id_registro", "id_alunos", "hora_saida", "hora_retorno", "tempo_gasto", "status_alunos"],
      "primaryKey": "id_registro",
      "foreignKeys": [{"column": "id_alunos", "references": "alunos(id_alunos)"}]
    },
    "fila_banheiro": {
      "columns": ["id_fila", "id_alunos", "hora_entrada_fila"],
      "primaryKey": "id_fila",
      "foreignKeys": [{"column": "id_alunos", "references": "alunos(id_alunos)"}]
    }
  }
}
